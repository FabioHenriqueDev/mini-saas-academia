generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int    @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  cpf       String   @unique
  personal  Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  exercisesAsClient   Exercise[] @relation("ClientExercises")
  exercisesAsPersonal Exercise[] @relation("PersonalExercises")
  @@map("users")
}

model Exercise {
  id            Int      @id @default(autoincrement())
  exercise_name String
  descricao     String
  series        Int
  repeticoes    Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  id_usuario    Int
  usuario       User     @relation("ClientExercises", fields: [id_usuario], references: [id]) 
  id_personal   Int
  personal      User     @relation("PersonalExercises", fields: [id_personal], references: [id]) 
  @@map("exercises")
}